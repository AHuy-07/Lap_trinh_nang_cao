<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox fx:controller="client.controllers.WalletController"
      spacing="20" alignment="TOP_CENTER" prefWidth="650" prefHeight="700"
      style="-fx-background-color: #f8f9fa;"
      xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17">

    <padding>
        <Insets top="25" right="30" bottom="25" left="30"/>
    </padding>

    <!-- Tiêu đề trang -->
    <StackPane>
        <Label text="Quản Lý Ví Đấu Giá"
               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

        <Button text="Back" onAction="#goBack" StackPane.alignment="CENTER_LEFT"
                style="-fx-background-color: white; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-background-radius: 5;
                       -fx-text-fill: #34495e; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;
                       -fx-padding: 8 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);"/>
        <Label fx:id="status" managed="false" style="-fx-text-fill: #DC3545; -fx-font-style: italic; -fx-font-size: 13px;" text="" visible="false" />
    </StackPane>

    <!-- Khung hiển thị số dư -->
    <HBox spacing="15" alignment="CENTER"
          style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;
                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
        <Label text="Số dư khả dụng:" style="-fx-font-size: 18px; -fx-text-fill: #7f8c8d;"/>
        <Label fx:id="lblBalance"
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
    </HBox>

    <!-- Khu vực chức năng Nạp / Rút -->
    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS"
             style="-fx-background-color: transparent;">
        <tabs>
            <!-- TAB: NẠP TIỀN -->
            <Tab text="📥 Nạp Tiền">
                <VBox spacing="20"
                      style="-fx-padding: 25; -fx-background-color: white;
                             -fx-border-color: #e0e0e0; -fx-border-width: 0 1 1 1; -fx-background-radius: 0 0 8 8;">
                    <GridPane hgap="15" vgap="20">
                        <columnConstraints>
                            <ColumnConstraints minWidth="120" />
                            <ColumnConstraints hgrow="ALWAYS" />
                        </columnConstraints>

                        <Label text="Số tiền (VNĐ):" GridPane.columnIndex="0" GridPane.rowIndex="0"
                               style="-fx-font-size: 14px;"/>
                        <TextField fx:id="txtDepositAmount" promptText="Nhập số tiền cần nạp..."
                                   GridPane.columnIndex="1" GridPane.rowIndex="0" prefHeight="35"/>

                        <Label text="Nguồn tiền:" GridPane.columnIndex="0" GridPane.rowIndex="1"
                               style="-fx-font-size: 14px;"/>
                        <ComboBox fx:id="cbDepositMethod" promptText="-- Chọn phương thức thanh toán --"
                                  GridPane.columnIndex="1" GridPane.rowIndex="1" maxWidth="Infinity" prefHeight="35"/>

                    </GridPane>

                    <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 10 0 0 0;">
                        <Label fx:id="lblDepositError" style="-fx-text-fill: #e74c3c; -fx-font-style: italic; -fx-font-size: 13px;" text=""/>

                        <Button text="Hủy" style="-fx-background-color: transparent; -fx-text-fill: #7f8c8d; -fx-font-size: 14px;"/>
                        <Button fx:id="btnConfirmDeposit" text="Xác Nhận Nạp Tiền"
                                style="-fx-background-color: #3498db; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-padding: 10 25; -fx-background-radius: 5; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </Tab>

            <!-- TAB: RÚT TIỀN -->
            <Tab text="📤 Rút Tiền">
                <VBox spacing="20"
                      style="-fx-padding: 25; -fx-background-color: white;
                             -fx-border-color: #e0e0e0; -fx-border-width: 0 1 1 1; -fx-background-radius: 0 0 8 8;">
                    <GridPane hgap="15" vgap="20">
                        <columnConstraints>
                            <ColumnConstraints minWidth="120" />
                            <ColumnConstraints hgrow="ALWAYS" />
                        </columnConstraints>

                        <Label text="Số tiền rút (VNĐ):" GridPane.columnIndex="0" GridPane.rowIndex="0"
                               style="-fx-font-size: 14px;"/>
                        <TextField fx:id="txtWithdrawAmount" promptText="Nhập số tiền cần rút..."
                                   GridPane.columnIndex="1" GridPane.rowIndex="0" prefHeight="35"/>

                        <Label text="Chuyển về:" GridPane.columnIndex="0" GridPane.rowIndex="1"
                               style="-fx-font-size: 14px;"/>
                        <ComboBox fx:id="cbWithdrawBank" promptText="-- Chọn ngân hàng đã liên kết --"
                                  GridPane.columnIndex="1" GridPane.rowIndex="1" maxWidth="Infinity" prefHeight="35"/>

                    </GridPane>

                    <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 10 0 0 0;">
                        <Label fx:id="lblWithdrawError" style="-fx-text-fill: #e74c3c; -fx-font-style: italic; -fx-font-size: 13px;" text=""/>
                        <Button text="Hủy" style="-fx-background-color: transparent; -fx-text-fill: #7f8c8d; -fx-font-size: 14px;"/>
                        <Button fx:id="btnConfirmWithdraw" text="Xác Nhận Rút Tiền"
                                style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-padding: 10 25; -fx-background-radius: 5; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </Tab>
        </tabs>
    </TabPane>

    <!-- Bảng lịch sử giao dịch -->
    <VBox spacing="10" VBox.vgrow="ALWAYS" style="-fx-padding: 10 0 0 0;">
        <Label text="Lịch sử giao dịch gần đây"
               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #34495e;"/>
        <TableView fx:id="tblTransactionHistory" prefHeight="200" VBox.vgrow="ALWAYS"
                   style="-fx-border-color: #bdc3c7; -fx-background-radius: 5; -fx-border-radius: 5;">
            <columns>
                <TableColumn fx:id="colDate" text="Thời gian" prefWidth="130"/>
                <TableColumn fx:id="colType" text="Loại Giao Dịch" prefWidth="120"/>
                <TableColumn fx:id="colAmount" text="Số tiền (VNĐ)" prefWidth="130"/>
                <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="100"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </VBox>

</VBox>