<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="300.0" prefWidth="300.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controllers.LoginController">
   <children>
      <PasswordField fx:id="txtPassword" layoutX="30.0" layoutY="131.0" promptText="Password">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </PasswordField>
      <TextField fx:id="txtUsername" layoutX="30.0" layoutY="74.0" promptText="Username">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </TextField>
      <Button layoutX="109.0" layoutY="216.0" mnemonicParsing="false" onAction="#Login" prefHeight="39.0" prefWidth="82.0" text="Login">
         <font>
            <Font size="18.0" />
         </font>
      </Button>
      <Button layoutX="122.0" layoutY="261.0" mnemonicParsing="false" text="Sign up" />
      <Label fx:id="loginStatusLabel" alignment="CENTER" contentDisplay="CENTER" layoutX="29.0" layoutY="183.0" prefHeight="17.0" prefWidth="240.0" textAlignment="CENTER" textFill="#cd2222" />
   </children>
</AnchorPane>
