<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controllers.loginAndSignUp.LoginController">
      <children>
         <PasswordField fx:id="txtPassword" layoutX="211.0" layoutY="189.0" prefHeight="39.0" prefWidth="179.0" promptText="Password">
            <font>
               <Font name="System Bold" size="18.0" />
            </font>
         </PasswordField>
         <TextField fx:id="txtUsername" layoutX="211.0" layoutY="126.0" prefHeight="39.0" prefWidth="179.0" promptText="Username">
            <font>
               <Font name="System Bold" size="18.0" />
            </font>
         </TextField>
         <Button layoutX="271.0" layoutY="264.0" mnemonicParsing="false" onAction="#Login" prefHeight="39.0" prefWidth="58.0" text="Login">
            <font>
               <Font size="14.0" />
            </font>
         </Button>
         <Button layoutX="271.0" layoutY="318.0" mnemonicParsing="false" onAction="#SignUp" text="Sign Up" />
         <Label fx:id="loginStatusLabel" alignment="CENTER" contentDisplay="CENTER" layoutX="180.0" layoutY="88.0" prefHeight="17.0" prefWidth="240.0" textAlignment="CENTER" textFill="#cd2222" />
      </children>
</AnchorPane>
