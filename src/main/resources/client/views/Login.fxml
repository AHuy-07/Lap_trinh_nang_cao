<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="768.0" prefWidth="1024.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controllers.loginAndSignUp.LoginController">
      <children>
         <PasswordField fx:id="txtPassword" layoutX="359.0" layoutY="384.0" prefHeight="66.0" prefWidth="307.0" promptText="Password">
            <font>
               <Font name="System Bold" size="18.0" />
            </font>
         </PasswordField>
         <TextField fx:id="txtUsername" layoutX="359.0" layoutY="283.0" prefHeight="66.0" prefWidth="307.0" promptText="Username">
            <font>
               <Font name="System Bold" size="18.0" />
            </font>
         </TextField>
         <Button layoutX="443.0" layoutY="478.0" mnemonicParsing="false" onAction="#Login" prefHeight="53.0" prefWidth="139.0" text="Login">
            <font>
               <Font size="14.0" />
            </font>
         </Button>
         <Button layoutX="443.0" layoutY="547.0" mnemonicParsing="false" onAction="#SignUp" prefHeight="53.0" prefWidth="139.0" text="Sign Up" />
         <Label fx:id="loginStatusLabel" alignment="CENTER" contentDisplay="CENTER" layoutX="359.0" layoutY="168.0" prefHeight="105.0" prefWidth="307.0" textAlignment="CENTER" textFill="#cd2222" />
      </children>
</AnchorPane>
