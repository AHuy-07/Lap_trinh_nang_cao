<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="400.0" prefWidth="600.0" spacing="25" style="-fx-background-color: #F8F9FA; -fx-font-family: 'Segoe UI', Arial, sans-serif;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controllers.sellerController.SellerProductsController">
    <padding>
        <Insets bottom="30" left="30" right="30" top="30" />
    </padding>
    <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #333333;" text="Quản lý sản phẩm">
        <font>
            <Font name="System Bold" size="14.0" />
        </font>
        <cursor>
            <Cursor fx:constant="HAND" />
        </cursor></Label>

    <!-- Bảng danh sách vật phẩm -->
    <TableView fx:id="tableMyProducts" prefHeight="218.0" prefWidth="610.0" style="-fx-background-color: white; -fx-border-color: #DEE2E6; -fx-border-radius: 5;" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colProductId" prefWidth="82.0" text="Mã sản phẩm" />
            <TableColumn fx:id="colProductName" prefWidth="91.0" text="Tên sản phẩm" />
            <TableColumn fx:id="colProductType" prefWidth="92.0" text="Loại sản phẩm" />
            <TableColumn fx:id="colProductStatus" prefWidth="83.0" text="Trạng thái" />
            <TableColumn fx:id="colProductWinPrice" prefWidth="76.0" text="Giá thắng" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="10">
      <Button mnemonicParsing="false" onAction="#switchToDashboard" prefHeight="23.0" prefWidth="92.0" text="Quay lại" />
        <Button onAction="#switchToAddProduct" style="-fx-background-color: #0D6EFD; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 10 20 10 20; -fx-background-radius: 5; -fx-cursor: hand;" text="+ Thêm sản phẩm mới" />
    </HBox>
</VBox>
