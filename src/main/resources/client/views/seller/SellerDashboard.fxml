<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controllers.sellerController.SellerDashboardController">

    <VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="800.0" spacing="20" style="-fx-background-color: #f4f4f4;">

        <padding>
            <Insets bottom="20" left="20" right="20" top="20" />
        </padding>

        <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="DANH SÁCH PHÒNG ĐẤU GIÁ CỦA TÔI" />

        <HBox alignment="CENTER_RIGHT" spacing="10">
            <Button onAction="#switchToWalletView" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;" text="💳 Ví Nạp/Rút" />
            <Button onAction="#switchToProductView" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand;" text="Quản lý Sản phẩm" />
            <Button onAction="#reload" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-cursor: hand;" text="Làm mới" />
            <Button onAction="#switchToCreateRoom" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="+ Tạo phòng mới" />
        </HBox>

        <TableView fx:id="tableMyRooms" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colRoomId" prefWidth="100" text="Mã phòng" />
                <TableColumn fx:id="colRoomName" prefWidth="250" text="Tên phòng đấu giá" />
                <TableColumn fx:id="colStatus" prefWidth="150" text="Trạng thái" />
                <TableColumn fx:id="colAction" prefWidth="150" text="Thao tác" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>

    <HBox fx:id="notificationBox" alignment="CENTER" managed="false" maxHeight="50" maxWidth="450" style="-fx-background-color: #2ecc71; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 5);" visible="false" StackPane.alignment="TOP_CENTER">
        <StackPane.margin>
            <Insets top="10" />
        </StackPane.margin>
        <Label fx:id="lblNotification" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;" text="Phòng đã được duyệt!" />
    </HBox>
</StackPane>
