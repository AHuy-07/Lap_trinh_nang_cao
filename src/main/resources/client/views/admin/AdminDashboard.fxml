<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="400.0" prefWidth="600.0" spacing="20.0" style="-fx-background-color: #f5f6fa;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controllers.AdminDashboardController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="QUẢN LÝ DUYỆT PHÒNG ĐẤU GIÁ" textFill="#2f3640">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <TableView fx:id="tablePendingRooms" style="-fx-background-radius: 5; -fx-border-radius: 5;" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colRoomId" prefWidth="100.0" text="Mã Phòng" />
            <TableColumn fx:id="colRoomName" prefWidth="200.0" text="Tên Phòng Đấu Giá" />
            <TableColumn fx:id="colProductId" prefWidth="120.0" text="Mã Sản Phẩm" />
            <TableColumn fx:id="colPrice" prefWidth="150.0" text="Giá Khởi Điểm (VNĐ)" />
            <TableColumn fx:id="colAction" prefWidth="200.0" text="Thao Tác" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button onAction="#reload" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="Làm mới danh sách" />
    </HBox>
</VBox>
