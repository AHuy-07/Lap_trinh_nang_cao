<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controllers.SignUpController">
   <children>
      <Label alignment="CENTER" contentDisplay="CENTER" layoutX="195.0" layoutY="48.0" prefHeight="17.0" prefWidth="210.0" text="Sign Up">
         <font>
            <Font size="24.0" />
         </font>
      </Label>
      <PasswordField fx:id="re_passwordSignUp" layoutX="180.0" layoutY="231.0" promptText="Re-enter password">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </PasswordField>
      <PasswordField fx:id="passwordSignUp" layoutX="180.0" layoutY="181.0" promptText="Password">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </PasswordField>
      <TextField fx:id="usernameSignUp" layoutX="180.0" layoutY="122.0" promptText="Username">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </TextField>
      <Button layoutX="274.0" layoutY="347.0" mnemonicParsing="false" onAction="#SignUp" text="Sign Up" />
      <Label fx:id="signUpError" alignment="CENTER" layoutX="179.0" layoutY="297.0" prefHeight="17.0" prefWidth="240.0" textFill="#e11b1b" />
   </children>
</AnchorPane>
